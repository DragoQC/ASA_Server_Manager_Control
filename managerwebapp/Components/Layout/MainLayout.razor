@inherits LayoutComponentBase

<div class="grid min-h-screen grid-cols-1 bg-black/5 text-neutral-100 lg:grid-cols-[18rem_minmax(0,1fr)]">
    <div class="border-b border-cyan-400/10 bg-black/20 backdrop-blur-xl lg:border-b-0 lg:border-r">
        <NavMenu />
    </div>

    <main class="flex min-h-screen flex-col">
        <div class="flex items-center justify-between border-b border-cyan-400/10 bg-black/20 px-6 py-4 backdrop-blur-xl">
            <div>
                <p class="text-[0.7rem] uppercase tracking-[0.35em] text-cyan-200/80">Manager Web App</p>
                <h1 class="text-lg font-semibold text-white">Global ASA control</h1>
            </div>
        </div>

        <article class="relative z-10 flex-1 px-6 py-6">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
