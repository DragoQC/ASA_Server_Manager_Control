@page "/admin/login"
@layout AuthLayout

<PageTitle>Login</PageTitle>

<section class="w-full max-w-xl rounded-[2rem] border border-fuchsia-300/15 bg-black/25 p-8 shadow-[0_0_70px_rgba(168,85,247,0.14)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-fuchsia-300">Connection</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                Login required
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Connect to the manager</h1>
            <p class="mt-4 max-w-2xl text-base leading-7 text-neutral-300">
                Sign in to unlock the panel. Default first access is <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">admin</code> / <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">admin</code>.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100">
                @Error
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-2xl border border-fuchsia-300/20 bg-fuchsia-400/10 px-5 py-4 text-sm text-fuchsia-100">
                @Message
            </div>
        }

        <form method="post" action="/auth/login" @formname="login" class="space-y-5">
            <div>
                <label for="username" class="mb-2 block text-sm font-medium text-neutral-300">Username</label>
                <input id="username"
                       name="username"
                       value="admin"
                       autocomplete="username"
                       class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
            </div>

            <div>
                <label for="password" class="mb-2 block text-sm font-medium text-neutral-300">Password</label>
                <input id="password"
                       name="password"
                       type="password"
                       value="admin"
                       autocomplete="current-password"
                       class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
            </div>

            <button type="submit" class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25">
                Connect
            </button>
        </form>
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery]
    private string? Message { get; set; }
}
