@page "/admin/settings"
@inject NavigationManager NavigationManager

<PageTitle>Settings</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Settings</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                Local control app
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Settings</h1>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                This page will show settings for the current manager app, including local app behavior, operator access, and supporting control-surface options.
            </p>
        </div>

        <div class="grid gap-4 lg:grid-cols-2">
            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Account</p>
                <p class="mt-3 text-2xl font-semibold text-white">Security access</p>
                <p class="mt-2 text-sm text-neutral-300">Reset password stays available here instead of living directly in the main navigation.</p>
                <button type="button"
                        @onclick="OpenResetPasswordPage"
                        class="mt-4 inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25">
                    Open reset password
                </button>
            </div>

            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Manager App</p>
                <p class="mt-3 text-2xl font-semibold text-white">Coming soon</p>
                <p class="mt-2 text-sm text-neutral-300">Current-app settings will land here for local manager behavior, fleet defaults, and future admin tools.</p>
            </div>
        </div>
    </div>
</section>

@code {
    private void OpenResetPasswordPage()
    {
        NavigationManager.NavigateTo("/admin/reset-password");
    }
}
