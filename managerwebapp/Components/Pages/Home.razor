@page "/"

<PageTitle>Manager Dashboard</PageTitle>

<div class="mx-auto flex max-w-6xl flex-col gap-6">
    <section class="rounded-[2rem] border border-cyan-400/15 bg-black/20 p-8 shadow-[0_0_40px_rgba(34,211,238,0.12)] backdrop-blur-xl">
        <p class="text-[0.7rem] uppercase tracking-[0.35em] text-cyan-200/80">Multi-server control</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">Manager dashboard</h1>
        <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
            This app will centralize remote ASA server panels, auth, email settings, and shared server connections.
        </p>
    </section>

    <section class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-[1.75rem] border border-cyan-400/15 bg-black/20 p-6 backdrop-blur-xl">
            <p class="text-[0.7rem] uppercase tracking-[0.3em] text-cyan-200/80">Auth</p>
            <p class="mt-3 text-2xl font-semibold text-white">Ready</p>
            <p class="mt-2 text-sm text-neutral-300">SQLite-backed identity is wired for the manager app.</p>
        </div>

        <div class="rounded-[1.75rem] border border-cyan-400/15 bg-black/20 p-6 backdrop-blur-xl">
            <p class="text-[0.7rem] uppercase tracking-[0.3em] text-cyan-200/80">Email</p>
            <p class="mt-3 text-2xl font-semibold text-white">Ready</p>
            <p class="mt-2 text-sm text-neutral-300">SMTP settings entity is ready for manager-side notifications.</p>
        </div>

        <div class="rounded-[1.75rem] border border-cyan-400/15 bg-black/20 p-6 backdrop-blur-xl">
            <p class="text-[0.7rem] uppercase tracking-[0.3em] text-cyan-200/80">Remote Servers</p>
            <p class="mt-3 text-2xl font-semibold text-white">Ready</p>
            <p class="mt-2 text-sm text-neutral-300">Remote server records will store IP and hashed API keys only.</p>
        </div>
    </section>
</div>
