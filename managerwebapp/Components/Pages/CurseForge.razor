@page "/admin/curseforge"
@inject managerwebapp.Services.CurseForgeService CurseForgeService
@inject managerwebapp.Services.RemoteServerModsService RemoteServerModsService

<PageTitle>CurseForge</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">CurseForge</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                Mod cache
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">CurseForge</h1>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                Store the CurseForge API key here so this control app can cache mod metadata for the full fleet: names, summaries, links, and logos.
            </p>
        </div>

        @if (!_hasApiKey)
        {
            <div class="rounded-[1.5rem] border border-amber-300/20 bg-amber-400/10 px-5 py-4 text-sm text-amber-100">
                CurseForge API key missing. Fleet mod ids can still be stored, but descriptions, links, and images stay locked until a key is configured.
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="rounded-[1.5rem] border border-fuchsia-300/20 bg-fuchsia-400/10 px-5 py-4 text-sm text-fuchsia-100">
                @_statusMessage
            </div>
        }

        <div class="grid gap-4 lg:grid-cols-3">
            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Cached mods</p>
                <p class="mt-3 text-3xl font-semibold text-white">@_cachedModCount</p>
                <p class="mt-2 text-sm text-neutral-300">Unique mod entries stored locally for the fleet.</p>
            </div>

            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Fleet-linked mods</p>
                <p class="mt-3 text-3xl font-semibold text-white">@_fleetLinkedModCount</p>
                <p class="mt-2 text-sm text-neutral-300">Mods currently linked to at least one known server.</p>
            </div>

            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Fleet sync</p>
                <p class="mt-3 text-2xl font-semibold text-white">Remote refresh</p>
                <p class="mt-2 text-sm text-neutral-300">Poll all accepted nodes for mod ids, then fill any missing local mod metadata from CurseForge.</p>
                <div class="mt-4">
                    <ActionButton Text="@(_isSyncingFleet ? "Syncing..." : "Sync fleet mods")"
                                  OnClick="SyncFleetModsAsync"
                                  Disabled="@_isSyncingFleet" />
                </div>
            </div>
        </div>

        <EditForm Model="_settings" OnValidSubmit="SaveAsync" FormName="curseforge-settings" class="space-y-5">
            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_auto_auto] lg:items-end">
                    <TextField Label="CurseForge API key"
                               @bind-Value="_settings.ApiKey"
                               Hint="Used for GET /v1/mods/{modId}. Stored locally so missing mod entries can be populated into the control database."
                               type="password" />

                    <ActionButton Text="@(_isSaving ? "Saving..." : "Save key")"
                                  ButtonType="submit"
                                  Disabled="@_isSaving" />

                    <ActionButton Text="@(_isRefreshingMods ? "Refreshing..." : "Refresh cached mods")"
                                  OnClick="RefreshCachedModsAsync"
                                  Disabled="@(_isRefreshingMods || !_hasApiKey)"
                                  Secondary="true" />
                </div>
            </div>
        </EditForm>

        @if (_mods.Count == 0)
        {
            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Mods</p>
                <p class="mt-3 text-2xl font-semibold text-white">No cached mods yet</p>
                <p class="mt-2 text-sm text-neutral-300">Once at least one remote server reports mod ids and the API key is set, the cache will populate here.</p>
            </div>
        }
        else
        {
            <div class="grid gap-4 lg:grid-cols-3">
                @foreach (managerwebapp.Models.CurseForge.CurseForgeCachedModItem mod in _mods)
                {
                    <article class="group overflow-hidden rounded-[1.6rem] border border-fuchsia-200/12 bg-black/40 shadow-[0_0_40px_rgba(168,85,247,0.08)] backdrop-blur-md">
                        @if (!string.IsNullOrWhiteSpace(mod.WebsiteUrl))
                        {
                            <a href="@mod.WebsiteUrl"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="block">
                                <div class="relative h-40 overflow-hidden border-b border-fuchsia-200/10 bg-gradient-to-br from-fuchsia-400/15 via-[#07121d] to-violet-400/10">
                                    @if (!string.IsNullOrWhiteSpace(mod.LogoUrl))
                                    {
                                        <img src="@mod.LogoUrl" alt="@mod.Name" class="h-full w-full object-cover opacity-90 transition duration-300 group-hover:scale-[1.03]" />
                                        <div class="absolute inset-0 bg-gradient-to-t from-[#05070d] via-[#05070d]/20 to-transparent"></div>
                                    }
                                    else
                                    {
                                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(192,132,252,0.22),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(167,139,250,0.18),transparent_35%)]"></div>
                                        <div class="absolute inset-0 flex items-center justify-center">
                                            <div class="h-16 w-16 rounded-2xl border border-fuchsia-300/20 bg-black/25"></div>
                                        </div>
                                    }
                                </div>
                            </a>
                        }
                        else
                        {
                            <div class="relative h-40 overflow-hidden border-b border-fuchsia-200/10 bg-gradient-to-br from-fuchsia-400/15 via-[#07121d] to-violet-400/10">
                                @if (!string.IsNullOrWhiteSpace(mod.LogoUrl))
                                {
                                    <img src="@mod.LogoUrl" alt="@mod.Name" class="h-full w-full object-cover opacity-90 transition duration-300 group-hover:scale-[1.03]" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-[#05070d] via-[#05070d]/20 to-transparent"></div>
                                }
                                else
                                {
                                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(192,132,252,0.22),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(167,139,250,0.18),transparent_35%)]"></div>
                                    <div class="absolute inset-0 flex items-center justify-center">
                                        <div class="h-16 w-16 rounded-2xl border border-fuchsia-300/20 bg-black/25"></div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="space-y-4 p-6">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-xs uppercase tracking-[0.3em] text-fuchsia-200/70">Mod</p>
                                    <h3 class="mt-2 text-2xl font-semibold text-white">@mod.Name</h3>
                                </div>
                                <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                                    @mod.ModId
                                </span>
                            </div>

                            <p class="text-sm leading-6 text-neutral-300">@mod.Summary</p>

                            <div class="flex items-center justify-between gap-3 text-sm text-neutral-400">
                                <span>@mod.DownloadCount downloads</span>
                                <span>@(mod.DateModifiedUtc?.LocalDateTime.ToString() ?? "Unknown update")</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(mod.WebsiteUrl))
                            {
                                <ActionButton Text="CurseForge"
                                              Href="@mod.WebsiteUrl"
                                              Target="_blank" />
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

@code {
    private managerwebapp.Models.CurseForge.CurseForgeApiSettingsModel _settings = new();
    private IReadOnlyList<managerwebapp.Models.CurseForge.CurseForgeCachedModItem> _mods = [];
    private int _cachedModCount;
    private int _fleetLinkedModCount;
    private bool _hasApiKey;
    private bool _isSaving;
    private bool _isRefreshingMods;
    private bool _isSyncingFleet;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        managerwebapp.Models.CurseForge.CurseForgeDashboardModel dashboard = await CurseForgeService.LoadDashboardAsync();
        _settings = dashboard.Settings;
        _hasApiKey = dashboard.HasApiKey;
        _mods = dashboard.CachedMods;
        _cachedModCount = dashboard.CachedModCount;
        _fleetLinkedModCount = dashboard.FleetLinkedModCount;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            await CurseForgeService.SaveSettingsAsync(_settings);
            _statusMessage = "CurseForge API key saved.";
            await LoadAsync();
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RefreshCachedModsAsync()
    {
        if (!_hasApiKey)
        {
            _statusMessage = "Add CurseForge API key to refresh descriptions, links, and images.";
            return;
        }

        _isRefreshingMods = true;
        _statusMessage = null;

        try
        {
            await CurseForgeService.RefreshAllCachedModsAsync();
            _statusMessage = "Cached CurseForge mods refreshed.";
            await LoadAsync();
        }
        finally
        {
            _isRefreshingMods = false;
        }
    }

    private async Task SyncFleetModsAsync()
    {
        _isSyncingFleet = true;
        _statusMessage = null;

        try
        {
            await RemoteServerModsService.SyncAcceptedServersAsync();
            _statusMessage = _hasApiKey
                ? "Fleet mods synced from remote servers."
                : "Fleet mod ids synced. Add CurseForge API key to populate descriptions, links, and images.";
            await LoadAsync();
        }
        finally
        {
            _isSyncingFleet = false;
        }
    }
}
