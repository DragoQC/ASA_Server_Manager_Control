@namespace ASA.ServerController.Components.Shared

<div class="@ContainerClass">
    <label class="block text-[0.7rem] uppercase tracking-[0.2em] text-fuchsia-200/70">
        @Label
        @if (IsServerManaged)
        {
            <span class="text-amber-400" title="Managed by server config">*</span>
        }
    </label>
    @if (!string.IsNullOrEmpty(Hint))
    {
        <p class="mt-1 text-xs text-neutral-400">@Hint</p>
    }
    <textarea @bind="@Value"
              placeholder="@Placeholder"
              rows="@Rows"
              class="@TextAreaClass" />
</div>

@code {
    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public bool IsServerManaged { get; set; }

    [Parameter]
    public string Hint { get; set; } = string.Empty;

    [Parameter]
    public string Placeholder { get; set; } = string.Empty;

    [Parameter]
    public int Rows { get; set; } = 3;

    private string ContainerClass => "col-span-full";

    private string TextAreaClass => "mt-2 w-full rounded-lg border border-white/10 bg-black/30 px-4 py-2.5 text-sm text-neutral-100 placeholder-neutral-500 outline-none transition focus:border-fuchsia-400/50 focus:ring-1 focus:ring-fuchsia-400/30 resize-none";
}
