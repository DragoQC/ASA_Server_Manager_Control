@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject asa_server_controller.Services.AuthService AuthService

@code {
    [Parameter, EditorRequired]
    public RouteData RouteData { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        AuthenticationState authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        bool isAuthenticated = authenticationState.User.Identity?.IsAuthenticated == true;
        if (!isAuthenticated)
        {
            return;
        }

        bool mustChangePassword = await AuthService.MustChangePasswordAsync(authenticationState.User);
        bool isLoginPage = RouteData.PageType == typeof(global::asa_server_controller.Components.Pages.Login);
        bool isResetPasswordPage = RouteData.PageType == typeof(global::asa_server_controller.Components.Pages.ResetPassword);

        if (mustChangePassword && !isResetPasswordPage)
        {
            NavigationManager.NavigateTo("/admin/reset-password?firstLogin=true", forceLoad: true);
            return;
        }

        if (!mustChangePassword && isLoginPage)
        {
            NavigationManager.NavigateTo("/admin/dashboard", forceLoad: true);
        }
    }
}
