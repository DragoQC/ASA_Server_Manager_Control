@page "/admin/ini-files"
@inject asa_server_controller.Services.RemoteServerService RemoteServerService
@inject asa_server_controller.Services.RemoteServerInfoService RemoteServerInfoService
@inject asa_server_controller.Services.InvitationEventsService InvitationEventsService
@implements IDisposable

<PageTitle>Ini Files</PageTitle>

<section class="rounded-b-4xl border-x border-b border-fuchsia-400/15 bg-linear-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Ini files</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                Config editor
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Ini Files</h1>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                Switch between per-server targeting and the shared default ini files. The apply flow stays disabled for now.
            </p>
        </div>

        <section class="rounded-[1.8rem] border border-white/10 bg-black/20 p-3 backdrop-blur">
            <div class="flex flex-wrap gap-3 p-2 sm:grid sm:grid-cols-2">
                <button type="button"
                        @onclick='() => SetTab("server")'
                        class="@GetTabClass("server")">
                    Per server
                </button>
                <button type="button"
                        @onclick='() => SetTab("global")'
                        class="@GetTabClass("global")">
                    Global defaults
                </button>
            </div>

            <div class="mt-6">
                @if (string.Equals(_activeTab, "server", StringComparison.Ordinal))
                {
                    <div class="@GetPanelClass()">
                        <section class="space-y-6">
                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <div>
                                    <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Servers</p>
                                    <h2 class="mt-3 text-2xl font-semibold text-white">Per server list</h2>
                                    <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-300">
                                        Select a remote server later to manage its specific ini files. For now this is the server target list UI only.
                                    </p>
                                </div>

                                <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                                    @_items.Count server(s)
                                </span>
                            </div>

                            @if (_items.Count == 0)
                            {
                                <div class="rounded-[1.6rem] border border-white/10 bg-black/20 p-6 text-sm leading-6 text-neutral-300">
                                    No servers yet.
                                </div>
                            }
                            else
                            {
                                <div class="space-y-3">
                                    @foreach (asa_server_controller.Models.Servers.RemoteServerListItem item in _items)
                                    {
                                        <button type="button"
                                                class="flex w-full items-center justify-between gap-4 rounded-[1.6rem] border border-white/10 bg-black/20 px-5 py-4 text-left transition hover:border-fuchsia-300/20 hover:bg-white/5">
                                            <div class="min-w-0">
                                                <p class="truncate text-sm font-semibold text-white">@GetServerTitle(item)</p>
                                                <p class="mt-1 truncate text-xs text-neutral-400">@item.VpnAddress</p>
                                            </div>

                                            <StatusTag Text="@item.StateLabel" />
                                        </button>
                                    }
                                </div>
                            }
                        </section>
                    </div>
                }
                else
                {
                    <div class="@GetPanelClass()">
                        <section class="space-y-6">
                            <div class="flex flex-wrap items-start justify-between gap-4">
                                <div>
                                    <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Defaults</p>
                                    <h2 class="mt-3 text-2xl font-semibold text-white">Global ini files</h2>
                                    <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-300">
                                        These are the shared default <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">Game.ini</code> and <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">GameUserSettings.ini</code>.
                                    </p>
                                </div>

                                <button type="button"
                                        disabled="disabled"
                                        class="inline-flex rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-5 py-2.5 text-sm font-medium text-fuchsia-100 opacity-60">
                                    Apply all
                                </button>
                            </div>

                            <div class="grid gap-5">
                                <div class="rounded-[1.6rem] border border-white/10 bg-black/20 p-5">
                                    <p class="text-[0.7rem] uppercase tracking-[0.28em] text-fuchsia-200/85">Game.ini</p>
                                    <textarea readonly
                                              class="mt-4 min-h-56 w-full rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-neutral-200 outline-none">@_gameIniContent</textarea>
                                </div>

                                <div class="rounded-[1.6rem] border border-white/10 bg-black/20 p-5">
                                    <p class="text-[0.7rem] uppercase tracking-[0.28em] text-fuchsia-200/85">GameUserSettings.ini</p>
                                    <textarea readonly
                                              class="mt-4 min-h-72 w-full rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-neutral-200 outline-none">@_gameUserSettingsContent</textarea>
                                </div>
                            </div>
                        </section>
                    </div>
                }
            </div>
        </section>
    </div>
</section>

@code {
    private IReadOnlyList<asa_server_controller.Models.Servers.RemoteServerListItem> _items =
        Array.Empty<asa_server_controller.Models.Servers.RemoteServerListItem>();
    private string _activeTab = "server";

    private readonly string _gameIniContent = """
[/Script/ShooterGame.ShooterGameMode]
BabyMatureSpeedMultiplier=1.0
EggHatchSpeedMultiplier=1.0
"""
    ;

    private readonly string _gameUserSettingsContent = """
[ServerSettings]
ServerPVE=False
ShowMapPlayerLocation=True
AllowThirdPersonPlayer=True

[SessionSettings]
SessionName=ASA Server
"""
    ;

    protected override async Task OnInitializedAsync()
    {
        InvitationEventsService.Changed += OnInvitationChanged;
        RemoteServerInfoService.InfoUpdated += OnRemoteInfoUpdated;
        await RefreshAsync();
    }

    public void Dispose()
    {
        InvitationEventsService.Changed -= OnInvitationChanged;
        RemoteServerInfoService.InfoUpdated -= OnRemoteInfoUpdated;
    }

    private async Task RefreshAsync()
    {
        _items = await RemoteServerService.LoadAsync();
    }

    private void OnInvitationChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshAsync();
            StateHasChanged();
        });
    }

    private void OnRemoteInfoUpdated(int remoteServerId)
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshAsync();
            StateHasChanged();
        });
    }

    private void SetTab(string tab)
    {
        _activeTab = tab;
    }

    private string GetTabClass(string tab)
    {
        return string.Equals(_activeTab, tab, StringComparison.Ordinal)
            ? "inline-flex justify-center rounded-[1.2rem] border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-3 text-sm font-medium text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition"
            : "inline-flex justify-center rounded-[1.2rem] border border-white/10 bg-black/20 px-5 py-3 text-sm font-medium text-neutral-300 transition hover:border-fuchsia-300/20 hover:bg-white/5 hover:text-white";
    }

    private static string GetPanelClass()
    {
        return "rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur";
    }

    private static string GetServerTitle(asa_server_controller.Models.Servers.RemoteServerListItem item)
    {
        return string.IsNullOrWhiteSpace(item.ServerName)
            ? $"Server {item.Id}"
            : item.ServerName;
    }
}
