@namespace asa_server_controller.Components.Pages.IniFileGeneratorSections
@inject IJSRuntime JS
@using System.Text.Json

<section class="space-y-6">
    <div>
        <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Generator</p>
        <h2 class="mt-3 text-2xl font-semibold text-white">Game.ini builder</h2>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-300">
            Gameplay-focused values for a starter <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">Game.ini</code>.
        </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <TextField Label="Baby mature speed"
                   Value="@_babyMatureSpeedMultiplier"
                   ValueChanged="SetBabyMatureSpeedMultiplier"
                   Hint="Example: 1.0"
                   placeholder="@DefaultBabyMatureSpeedMultiplier" />

        <TextField Label="Egg hatch speed"
                   Value="@_eggHatchSpeedMultiplier"
                   ValueChanged="SetEggHatchSpeedMultiplier"
                   Hint="Example: 1.0"
                   placeholder="@DefaultEggHatchSpeedMultiplier" />

        <TextField Label="Harvest amount"
                   Value="@_harvestAmountMultiplier"
                   ValueChanged="SetHarvestAmountMultiplier"
                   Hint="Example: 1.0"
                   placeholder="@DefaultHarvestAmountMultiplier" />

        <TextField Label="XP multiplier"
                   Value="@_xpMultiplier"
                   ValueChanged="SetXpMultiplier"
                   Hint="Example: 1.0"
                   placeholder="@DefaultXpMultiplier" />

        <TextField Label="Taming speed"
                   Value="@_tamingSpeedMultiplier"
                   ValueChanged="SetTamingSpeedMultiplier"
                   Hint="Example: 1.0"
                   placeholder="@DefaultTamingSpeedMultiplier" />
    </div>

    <div class="rounded-[1.6rem] border border-white/10 bg-black/20 p-5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-fuchsia-200/85">Generated Game.ini</p>
        <textarea readonly
                  class="mt-4 min-h-80 w-full rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-neutral-200 outline-none">@BuildGameIniPreview()</textarea>
    </div>
</section>

@code {
    private const string StorageKey = "asa.ini-generator.game-ini";
    private const string DefaultBabyMatureSpeedMultiplier = "1.0";
    private const string DefaultEggHatchSpeedMultiplier = "1.0";
    private const string DefaultHarvestAmountMultiplier = "1.0";
    private const string DefaultXpMultiplier = "1.0";
    private const string DefaultTamingSpeedMultiplier = "1.0";

    private string _babyMatureSpeedMultiplier = string.Empty;
    private string _eggHatchSpeedMultiplier = string.Empty;
    private string _harvestAmountMultiplier = string.Empty;
    private string _xpMultiplier = string.Empty;
    private string _tamingSpeedMultiplier = string.Empty;
    private bool _loadedFromStorage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loadedFromStorage)
        {
            return;
        }

        _loadedFromStorage = true;
        string? raw = await JS.InvokeAsync<string>("iniGeneratorStorage.load", StorageKey);
        if (string.IsNullOrWhiteSpace(raw))
        {
            return;
        }

        Dictionary<string, string>? state = JsonSerializer.Deserialize<Dictionary<string, string>>(raw);
        if (state is null)
        {
            return;
        }

        _babyMatureSpeedMultiplier = state.TryGetValue(nameof(GameIniState.BabyMatureSpeedMultiplier), out string? babyMatureSpeedMultiplier)
            ? babyMatureSpeedMultiplier
            : string.Empty;
        _eggHatchSpeedMultiplier = state.TryGetValue(nameof(GameIniState.EggHatchSpeedMultiplier), out string? eggHatchSpeedMultiplier)
            ? eggHatchSpeedMultiplier
            : string.Empty;
        _harvestAmountMultiplier = state.TryGetValue(nameof(GameIniState.HarvestAmountMultiplier), out string? harvestAmountMultiplier)
            ? harvestAmountMultiplier
            : string.Empty;
        _xpMultiplier = state.TryGetValue(nameof(GameIniState.XpMultiplier), out string? xpMultiplier)
            ? xpMultiplier
            : string.Empty;
        _tamingSpeedMultiplier = state.TryGetValue(nameof(GameIniState.TamingSpeedMultiplier), out string? tamingSpeedMultiplier)
            ? tamingSpeedMultiplier
            : string.Empty;
        StateHasChanged();
    }

    private async Task PersistStateAsync()
    {
        Dictionary<string, string> state = new();

        AddIfEntered(state, nameof(GameIniState.BabyMatureSpeedMultiplier), _babyMatureSpeedMultiplier);
        AddIfEntered(state, nameof(GameIniState.EggHatchSpeedMultiplier), _eggHatchSpeedMultiplier);
        AddIfEntered(state, nameof(GameIniState.HarvestAmountMultiplier), _harvestAmountMultiplier);
        AddIfEntered(state, nameof(GameIniState.XpMultiplier), _xpMultiplier);
        AddIfEntered(state, nameof(GameIniState.TamingSpeedMultiplier), _tamingSpeedMultiplier);

        string payload = JsonSerializer.Serialize(state);
        await JS.InvokeVoidAsync("iniGeneratorStorage.save", StorageKey, payload);
    }

    private async Task SetBabyMatureSpeedMultiplier(string? value)
    {
        _babyMatureSpeedMultiplier = value ?? string.Empty;
        await PersistStateAsync();
    }

    private async Task SetEggHatchSpeedMultiplier(string? value)
    {
        _eggHatchSpeedMultiplier = value ?? string.Empty;
        await PersistStateAsync();
    }

    private async Task SetHarvestAmountMultiplier(string? value)
    {
        _harvestAmountMultiplier = value ?? string.Empty;
        await PersistStateAsync();
    }

    private async Task SetXpMultiplier(string? value)
    {
        _xpMultiplier = value ?? string.Empty;
        await PersistStateAsync();
    }

    private async Task SetTamingSpeedMultiplier(string? value)
    {
        _tamingSpeedMultiplier = value ?? string.Empty;
        await PersistStateAsync();
    }

    private string BuildGameIniPreview()
    {
        List<string> lines = [];

        if (HasUserValue(_babyMatureSpeedMultiplier) ||
            HasUserValue(_eggHatchSpeedMultiplier) ||
            HasUserValue(_harvestAmountMultiplier) ||
            HasUserValue(_xpMultiplier) ||
            HasUserValue(_tamingSpeedMultiplier))
        {
            lines.Add("[/Script/ShooterGame.ShooterGameMode]");

            AddPreviewIfEntered(lines, "BabyMatureSpeedMultiplier", _babyMatureSpeedMultiplier);
            AddPreviewIfEntered(lines, "EggHatchSpeedMultiplier", _eggHatchSpeedMultiplier);
            AddPreviewIfEntered(lines, "HarvestAmountMultiplier", _harvestAmountMultiplier);
            AddPreviewIfEntered(lines, "XPMultiplier", _xpMultiplier);
            AddPreviewIfEntered(lines, "TamingSpeedMultiplier", _tamingSpeedMultiplier);
        }

        return string.Join(System.Environment.NewLine, lines);
    }

    private static void AddIfEntered(Dictionary<string, string> state, string key, string value)
    {
        if (HasUserValue(value))
        {
            state[key] = value;
        }
    }

    private static void AddPreviewIfEntered(List<string> lines, string key, string value)
    {
        if (HasUserValue(value))
        {
            lines.Add($"{key}={value}");
        }
    }

    private static bool HasUserValue(string? value)
    {
        return !string.IsNullOrWhiteSpace(value);
    }

    private sealed record GameIniState(
        string BabyMatureSpeedMultiplier,
        string EggHatchSpeedMultiplier,
        string HarvestAmountMultiplier,
        string XpMultiplier,
        string TamingSpeedMultiplier);
}
