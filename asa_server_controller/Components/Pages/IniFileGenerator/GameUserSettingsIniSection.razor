@using System.Text.Json
@using asa_server_controller.Models.Ini
@inject IJSRuntime JS
@inject IWebHostEnvironment HostEnvironment
@namespace asa_server_controller.Components.Pages.IniFileGeneratorSections

<section class="space-y-6">
    <div>
        <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Generator</p>
        <h2 class="mt-3 text-2xl font-semibold text-white">GameUserSettings.ini builder</h2>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-300">
            Built from the ASA wiki table. Real server-managed values stay marked as managed, everything uncertain keeps a wiki check button.
        </p>
        <a href="https://ark.wiki.gg/wiki/Server_configuration"
           target="_blank"
           rel="noopener noreferrer"
           class="mt-3 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10">
            Open wiki source
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <div class="rounded-[1.4rem] border border-red-400/20 bg-red-500/10 p-4 text-sm text-red-100">
            @_loadError
        </div>
    }
    else
    {
        @foreach (GameUserSettingsSectionDefinition sectionDefinition in _sections)
        {
            IReadOnlyList<GameUserSettingsFieldDefinition> sectionFields = GetFieldsForSection(sectionDefinition.Key);

            if (sectionFields.Count == 0)
            {
                continue;
            }

            <section class="space-y-4 rounded-[1.6rem] border border-white/10 bg-black/15 p-5">
                <div>
                    <p class="text-[0.7rem] uppercase tracking-[0.28em] text-fuchsia-200/85">@sectionDefinition.Title</p>
                    @if (!string.IsNullOrWhiteSpace(sectionDefinition.Description))
                    {
                        <p class="mt-2 text-sm leading-6 text-neutral-300">@sectionDefinition.Description</p>
                    }
                </div>

                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                    @foreach (GameUserSettingsFieldDefinition field in sectionFields)
                    {
                        <div @key="field.Key">
                            @switch (NormalizeFieldType(field.Type))
                            {
                                case "boolinput":
                                    <BoolInput Title="@field.Title"
                                               Variable="@field.Key"
                                               Description="@field.Description"
                                               ValueType="@GetValueTypeLabel(field.Type)"
                                               AvailabilityLabel="@GetAvailabilityLabel(field)"
                                               InputLabel="Value"
                                               Note="@GetNote(field)"
                                               IsUncertain="@field.Uncertain"
                                               SourceUrl="@WikiSourceUrl"
                                               Placeholder="@GetPlaceholder(field)"
                                               OnHelpClick='@(() => OpenHelpDialog(field.Title, field.Description))'
                                               Value="@GetFieldValue(field.Key)"
                                               ValueChanged="@(value => SetFieldValue(field.Key, value))" />
                                    break;
                                case "intinput":
                                    <IntInput Title="@field.Title"
                                              Variable="@field.Key"
                                              Description="@field.Description"
                                              ValueType="@GetValueTypeLabel(field.Type)"
                                              AvailabilityLabel="@GetAvailabilityLabel(field)"
                                              InputLabel="Value"
                                              Note="@GetNote(field)"
                                              IsUncertain="@field.Uncertain"
                                              SourceUrl="@WikiSourceUrl"
                                              Placeholder="@GetPlaceholder(field)"
                                               OnHelpClick='@(() => OpenHelpDialog(field.Title, field.Description))'
                                               Value="@GetFieldValue(field.Key)"
                                               ValueChanged="@(value => SetFieldValue(field.Key, value))" />
                                    break;
                                case "floatinput":
                                    <FloatInput Title="@field.Title"
                                                Variable="@field.Key"
                                                Description="@field.Description"
                                                ValueType="@GetValueTypeLabel(field.Type)"
                                                AvailabilityLabel="@GetAvailabilityLabel(field)"
                                                InputLabel="Value"
                                                Note="@GetNote(field)"
                                                IsUncertain="@field.Uncertain"
                                                SourceUrl="@WikiSourceUrl"
                                                Placeholder="@GetPlaceholder(field)"
                                                OnHelpClick='@(() => OpenHelpDialog(field.Title, field.Description))'
                                                Value="@GetFieldValue(field.Key)"
                                                ValueChanged="@(value => SetFieldValue(field.Key, value))" />
                                    break;
                                default:
                                    <TextInput Title="@field.Title"
                                               Variable="@field.Key"
                                               Description="@field.Description"
                                               ValueType="@GetValueTypeLabel(field.Type)"
                                               AvailabilityLabel="@GetAvailabilityLabel(field)"
                                               InputLabel="Value"
                                               Note="@GetNote(field)"
                                               IsUncertain="@field.Uncertain"
                                               SourceUrl="@WikiSourceUrl"
                                               Placeholder="@GetPlaceholder(field)"
                                               IsTextArea="@IsTextArea(field.Type)"
                                               OnHelpClick='@(() => OpenHelpDialog(field.Title, field.Description))'
                                               Value="@GetFieldValue(field.Key)"
                                               ValueChanged="@(value => SetFieldValue(field.Key, value))" />
                                    break;
                            }
                        </div>
                    }
                </div>
            </section>
        }
    }

    <div class="rounded-[1.6rem] border border-white/10 bg-black/20 p-5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-fuchsia-200/85">Generated GameUserSettings.ini</p>
        <textarea readonly
                  class="mt-4 min-h-80 w-full rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-neutral-200 outline-none">@BuildGameUserSettingsPreview()</textarea>
    </div>
</section>

<InfoDialog IsOpen="@_showHelpDialog"
            Eyebrow="Ini"
            Title="@_helpDialogTitle"
            Message="@_helpDialogMessage"
            PillText="Help"
            OnClose="CloseHelpDialog" />

@code {
    private const string WikiSourceUrl = "https://ark.wiki.gg/wiki/Server_configuration";
    private const string StorageKey = "asa.ini-generator.gameusersettings";

    private readonly List<GameUserSettingsSectionDefinition> _sections = [];
    private readonly List<GameUserSettingsFieldDefinition> _fields = [];
    private readonly Dictionary<string, string?> _fieldValues = new(StringComparer.Ordinal);

    private bool _showHelpDialog;
    private bool _loadedFromStorage;
    private string _helpDialogTitle = string.Empty;
    private string _helpDialogMessage = string.Empty;
    private string _loadError = string.Empty;

    protected override void OnInitialized()
    {
        LoadCatalog();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loadedFromStorage)
        {
            return;
        }

        _loadedFromStorage = true;
        string? raw = await JS.InvokeAsync<string>("iniGeneratorStorage.load", StorageKey);
        if (string.IsNullOrWhiteSpace(raw))
        {
            return;
        }

        Dictionary<string, string?>? state = JsonSerializer.Deserialize<Dictionary<string, string?>>(raw);
        if (state is null)
        {
            return;
        }

        foreach ((string key, string? value) in state)
        {
            if (_fieldValues.ContainsKey(key))
            {
                _fieldValues[key] = value ?? string.Empty;
            }
        }

        StateHasChanged();
    }

    private void LoadCatalog()
    {
        try
        {
            string path = Path.Combine(HostEnvironment.ContentRootPath, "Resources", "Lang", "en.json");
            using JsonDocument doc = JsonDocument.Parse(File.ReadAllText(path));

            JsonElement root = doc.RootElement.GetProperty("gameusersettings");

            foreach (JsonProperty section in root.GetProperty("sections").EnumerateObject())
            {
                _sections.Add(new GameUserSettingsSectionDefinition(
                    section.Name,
                    section.Value.GetProperty("title").GetString() ?? section.Name,
                    section.Value.GetProperty("description").GetString() ?? string.Empty));
            }

            JsonElement translatedFields = root.GetProperty("fields");

            foreach (GameUserSettingsFieldCatalogItem catalogField in GameUserSettingsCatalog.Fields)
            {
                JsonElement translatedField = translatedFields.TryGetProperty(catalogField.Key, out JsonElement value)
                    ? value
                    : default;

                GameUserSettingsFieldDefinition definition = new(
                    catalogField.Key,
                    translatedField.ValueKind == JsonValueKind.Object && translatedField.TryGetProperty("title", out JsonElement titleElement)
                        ? titleElement.GetString() ?? catalogField.Key
                        : catalogField.Key,
                    translatedField.ValueKind == JsonValueKind.Object && translatedField.TryGetProperty("description", out JsonElement descriptionElement)
                        ? descriptionElement.GetString() ?? string.Empty
                        : string.Empty,
                    catalogField.Section,
                    catalogField.Type,
                    catalogField.IsServerManaged,
                    catalogField.Uncertain,
                    catalogField.DefaultValue,
                    catalogField.IsUnsupported);

                _fields.Add(definition);
                _fieldValues[definition.Key] = string.Empty;
            }
        }
        catch (Exception exception)
        {
            _loadError = $"Could not load GameUserSettings catalog. {exception.Message}";
        }
    }

    private IReadOnlyList<GameUserSettingsFieldDefinition> GetFieldsForSection(string sectionKey)
    {
        return _fields.Where(field => string.Equals(field.Section, sectionKey, StringComparison.Ordinal)).ToList();
    }

    private string? GetFieldValue(string key)
    {
        return _fieldValues.TryGetValue(key, out string? value) ? value : string.Empty;
    }

    private async Task SetFieldValue(string key, string? value)
    {
        _fieldValues[key] = value ?? string.Empty;
        await PersistStateAsync();
    }

    private async Task PersistStateAsync()
    {
        Dictionary<string, string?> modifiedValues = _fields
            .Where(field => HasUserValue(GetFieldValue(field.Key)))
            .ToDictionary(field => field.Key, field => GetFieldValue(field.Key), StringComparer.Ordinal);

        string payload = JsonSerializer.Serialize(modifiedValues);
        await JS.InvokeVoidAsync("iniGeneratorStorage.save", StorageKey, payload);
    }

    private string NormalizeFieldType(string type)
    {
        return type.ToLowerInvariant() switch
        {
            "textareainputservermanaged" => "textareainput",
            _ => type.ToLowerInvariant()
        };
    }

    private static bool IsTextArea(string type)
    {
        return string.Equals(type, "textareainput", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(type, "textareaInputServerManaged", StringComparison.OrdinalIgnoreCase);
    }

    private string GetValueTypeLabel(string type)
    {
        return NormalizeFieldType(type) switch
        {
            "boolinput" => "boolean",
            "intinput" => "integer",
            "floatinput" => "float",
            "textareainput" => "string",
            _ => "string"
        };
    }

    private static string GetAvailabilityLabel(GameUserSettingsFieldDefinition field)
    {
        if (field.IsServerManaged)
        {
            return "Server managed";
        }

        if (field.IsUnsupported)
        {
            return "Not in ASA";
        }

        return field.Uncertain ? "Check wiki" : "Supported";
    }

    private static string? GetNote(GameUserSettingsFieldDefinition field)
    {
        if (field.IsServerManaged)
        {
            return "Managed from Server Config.";
        }

        if (field.IsUnsupported)
        {
            return "Marked as unsupported for ASA on the wiki.";
        }

        if (field.Uncertain)
        {
            return "May not be supported in ASA. Verify on the wiki and test before relying on it.";
        }

        return null;
    }

    private string BuildGameUserSettingsPreview()
    {
        List<string> lines = [];

        foreach (GameUserSettingsSectionDefinition section in _sections)
        {
            List<string> sectionLines = [];

            foreach (GameUserSettingsFieldDefinition field in GetFieldsForSection(section.Key))
            {
                string? value = GetFieldValue(field.Key);
                if (!HasUserValue(value))
                {
                    continue;
                }

                sectionLines.Add($"{field.Key}={value}");
            }

            if (sectionLines.Count == 0)
            {
                continue;
            }

            if (lines.Count > 0)
            {
                lines.Add(string.Empty);
            }

            lines.Add(GetIniSectionHeader(section.Key));
            lines.AddRange(sectionLines);
        }

        return string.Join(System.Environment.NewLine, lines);
    }

    private static bool HasUserValue(string? value)
    {
        return !string.IsNullOrWhiteSpace(value);
    }

    private static string GetPlaceholder(GameUserSettingsFieldDefinition field)
    {
        return field.Key switch
        {
            "SessionName" => "ARK # ...",
            _ => string.IsNullOrWhiteSpace(field.DefaultValue) ? "Enter value" : field.DefaultValue
        };
    }

    private static string GetIniSectionHeader(string sectionKey)
    {
        return sectionKey switch
        {
            "serverSettings" => "[ServerSettings]",
            "sessionSettings" => "[SessionSettings]",
            "multiHome" => "[MultiHome]",
            "scriptEngineGameSession" => "[/Script/Engine.GameSession]",
            "messageOfTheDay" => "[MessageOfTheDay]",
            "cryoSickness" => "[CryoSickness]",
            "cryoHospital" => "[CryoHospital]",
            "bloodforge" => "[Bloodforge]",
            "textFiltering" => "[TextFiltering]",
            "crossArkTransfers" => "[CrossARKTransfers]",
            "tekBunker" => "[TekBunker]",
            "outposts" => "[Outposts]",
            "ragnarok" => "[Ragnarok]",
            _ => $"[{sectionKey}]"
        };
    }

    private void OpenHelpDialog(string title, string message)
    {
        _helpDialogTitle = title;
        _helpDialogMessage = message;
        _showHelpDialog = true;
    }

    private Task CloseHelpDialog()
    {
        _showHelpDialog = false;
        return Task.CompletedTask;
    }

    private sealed record GameUserSettingsSectionDefinition(
        string Key,
        string Title,
        string Description);

    private sealed record GameUserSettingsFieldDefinition(
        string Key,
        string Title,
        string Description,
        string Section,
        string Type,
        bool IsServerManaged,
        bool Uncertain,
        string DefaultValue,
        bool IsUnsupported);
}
